@model List<Destination>

<h2>Admin - Manage Offers</h2>

<a class="btn btn-success mb-3" href="/Admin/Create">Add New Destination</a>

<table class="table table-bordered">
    <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Price</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td>$@item.Price</td>
        </tr>
    }
</table>